# Edge Function secrets — set these in your Supabase dashboard
# (Project Settings -> Edge Functions -> Secrets) or via:
#   supabase secrets set --env-file supabase/.env
#
# These are NOT exposed to the frontend.

ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
VOYAGE_API_KEY=pa-your-voyage-key

# Local-only Google OAuth (when running `supabase start`)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
