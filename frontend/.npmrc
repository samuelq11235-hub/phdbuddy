# react-konva@19 declares react@19 as a strict peer dependency, but the
# rest of the project (and the React Server Components story) is on
# react@18. The library itself works fine against React 18 — only the
# package metadata is strict — so we tell npm to fall back to the v6
# behaviour and accept the mismatch.
#
# This is *required* for Vercel: its default install runs `npm install`
# with strict peer deps and fails the build without this file.
legacy-peer-deps=true
